{
  "name": "vite-react-starter",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "restart": "vite --force",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "eslint": "eslint --fix src/**/*.{ts,tsx}",
